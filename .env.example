# ── 安全密钥（必须替换，不能以 your- 开头）──────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ENCRYPTION_KEY=change-me-to-a-32-byte-base64url-or-hex-string

# ── JWT ──────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PRE_AUTH_TOKEN_EXPIRE_MINUTES=5

# ── 数据库 ────────────────────────────────────────────────────────────────
# MySQL（docker-compose 默认启动本地 MySQL 容器）
DB_TYPE=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=kiro
MYSQL_PASSWORD=change-this-local-mysql-password
MYSQL_ROOT_PASSWORD=change-this-local-root-password
MYSQL_DATABASE=kiro_fleet

# SQLite 仅用于隔离测试或无容器的临时开发
# DB_TYPE=sqlite
# SQLITE_PATH=./data/kiro_fleet.db

# ── 应用 ──────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOGIN_RATE_LIMIT_PER_MINUTE=10
DATA_DIR=./data
EXPORTS_DIR=./data/exports

# ── IAM Identity Center Trusted Token Issuer（导出可用 accessToken 所必需）─
# 配置步骤见 docs/deployment.md#aws-接入与导出配置
SSO_OIDC_CLIENT_ID=                   # IdC 应用 ARN
SSO_OIDC_PRIVATE_KEY_B64=             # RSA 私钥 PEM 文件的 base64 编码（base64 -w 0 tti-private.pem）
SSO_OIDC_ISSUER_URL=                  # 与 TTI IssuerUrl 完全一致的域名（如 https://xxx.s3.amazonaws.com/tti）
SSO_OIDC_AUDIENCE=kiro-fleet          # JWT aud 声明，必须在 TTI AuthorizedAudiences 内
SSO_OIDC_KEY_ID=kiro-fleet-tti-key-1  # JWKS 中对应公钥的 kid 字段
SSO_OIDC_REQUESTED_TOKEN_TYPE=urn:ietf:params:aws:token-type:iam_identity_center:access_token

# ── Scheduler ────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=10
PENDING_RETRY_INTERVAL_MINUTES=10

# ── 初始管理员（首次启动自动创建）────────────────────────────────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin@12345
INITIAL_ADMIN_EMAIL=admin@example.com
